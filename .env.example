# Supabase Configuration
VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SECRET_KEY=your-secret-key-here
DATABASE_PW=your-database-password-here

# Backend API Configuration
# Local:      http://localhost:8000
# Dev:        https://msanii-backend-dev-xxx-nn.a.run.app (deployed on push to main)
# Production: https://msanii-backend-xxx-nn.a.run.app (deployed on tag release v*)
VITE_BACKEND_API_URL=http://localhost:8000

# CORS Configuration (for backend deployment)
# Comma-separated list of allowed origins
# Dev:        Set via DEV_ALLOWED_ORIGINS GitHub secret (dev Vercel URL)
# Production: Set in deploy-backend.yml (prod Vercel URL)
ALLOWED_ORIGINS=http://localhost:8080

# OpenAI Configuration (for backend)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=
OPENAI_LLM_MODEL_LARGE=

# Claude Configuration
CLAUDE_API_KEY=
CLAUDE_MODEL=
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Vercel Deployment
VERCEL_PROD_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# --- Integration OAuth Credentials ---
# Google Drive: Create OAuth credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=

# Slack: Create an app at https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Encryption key for storing OAuth tokens at rest (AES-256 via Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=

# Secret for signing OAuth state JWTs (CSRF protection)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTEGRATION_OAUTH_STATE_SECRET=

# Encryption key for the Artist Credentials Vault (AES-256-GCM, 32 raw bytes, base64-encoded)
# Generate: python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CREDENTIALS_AES_KEY=

# Resend transactional email — domain must be verified at https://resend.com/domains
# RESEND_FROM_EMAIL is required (no fallback); use an address on a Resend-verified domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Msanii <noreply@msanii-beta.com>

# --- Pricing Tiers (Sub-project 2) ---

# Comma-separated list of email addresses authorized to use the /admin/* APIs
# and the /admin/users frontend console. Case-insensitive. Leave empty to
# disable admin functions (calls to /admin/me return 500).
# Example: ADMIN_EMAILS=tech@greenboxanalytics.ca,founder@greenboxanalytics.ca
ADMIN_EMAILS=

# Where Pro-access requests submitted via /pro-requests are emailed. Defaults to
# tech@greenboxanalytics.ca if unset.
OPS_NOTIFICATION_EMAIL=tech@greenboxanalytics.ca

# --- Stripe (Sub-project 4) ---

# Stripe API secret key. Test mode: starts with sk_test_; live mode: sk_live_.
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Webhook signing secret for /billing/webhook signature verification.
# Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Reveal signing secret.
# Different per environment (test vs live).
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs for the two Pro plans (create in Stripe Dashboard → Products).
# Format: price_XXXXXXXXXXXXXX
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=

# Frontend base URL — used to build Checkout/Portal success+cancel redirect URLs.
# Dev: http://localhost:8080
# Prod: https://app.msanii.com (or your live frontend domain)
FRONTEND_URL=http://localhost:8080

# --- Beta Paywall Bypass (Sub-project 3 / Beta Tester plan) ---

# Master switch. When "true", ALL users receive Pro-shaped entitlements (all
# caps = -1, all features = true) regardless of their subscription tier.
# Default: "true" during the private beta so no real user hits a paywall.
# Set to "false" once billing is live and you want paywalls to fire for real.
#
# Admin users (addresses in ADMIN_EMAILS above) always receive Pro entitlements
# at the /subscriptions/me endpoint even when this is "false", as long as
# is_admin is plumbed through. Full gate-level admin bypass is a post-beta
# follow-up; BYPASS_PAYWALLS=true covers everyone during the beta period.
BYPASS_PAYWALLS=true

# --- PostHog Analytics (2026-05-16 beta) ---

# Master toggle. Set to "true" in production + staging only; "false" disables
# all capture/identify calls (FE + BE) so dev/test environments don't pollute
# the project. Tests force this off via fixture regardless of value.
POSTHOG_ENABLED=false

# PostHog Project API Key (the public "Project key", NOT the personal/private key).
# Get from PostHog Dashboard → Project settings → Project API Key.
# Format: phc_XXXXXXXXXXXXXX. Safe to ship to the browser (it's public-by-design).
VITE_POSTHOG_API_KEY=
POSTHOG_API_KEY=

# PostHog API host. US cloud: https://us.i.posthog.com (default).
# EU cloud: https://eu.i.posthog.com. Self-hosted: your instance URL.
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# PostHog dashboard URL — set to your specific dashboard for one-click access from /admin/users.
# Defaults to https://us.posthog.com if unset.
VITE_POSTHOG_DASHBOARD_URL=https://us.posthog.com

# Comma-separated admin emails (frontend mirror of backend ADMIN_EMAILS).
# Used only to tag admin users in PostHog with `is_admin: true` person property
# so beta cohort dashboards can exclude internal usage.
VITE_ADMIN_EMAILS=

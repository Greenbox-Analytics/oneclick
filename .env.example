# ============================================================================
# Msanii — Environment Variables
# ----------------------------------------------------------------------------
# Local: copy to .env and fill in values, OR run `task setup:secrets:dev` to
#        merge from Google Secret Manager (preserves any live values you have).
# Prod:  stored in GSM, injected into Cloud Run + Vercel at deploy.
#
# Sections below mirror the GSM organization. See docs/secrets.md for a
# per-variable guide (required vs optional, where to source each, format).
# ============================================================================


# ============================================================================
# SUPABASE
# ============================================================================
# Dashboard → Project Settings → API for URL + keys.
# Database → Connection string for the password.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_SECRET_KEY=
DATABASE_PW=


# ============================================================================
# OPENAI API KEYS
# ============================================================================
# platform.openai.com → API keys. Powers Zoe + OneClick contract parsing.
# OPENAI_BASE_URL is optional — set only when using an OpenAI-compatible proxy.
OPENAI_API_KEY=
OPENAI_LLM_MODEL=
OPENAI_LLM_MODEL_LARGE=
OPENAI_BASE_URL=


# ============================================================================
# CLAUDE API KEYS
# ============================================================================
# Note: currently NOT read by any backend code — scaffolding for future use.
# Safe to leave blank.
CLAUDE_API_KEY=
CLAUDE_MODEL=
CLAUDE_BASE_URL=https://api.anthropic.com/v1


# ============================================================================
# VERCEL
# ============================================================================
# CI-only — used by GitHub Actions deploy workflows. Not needed locally.
# Stored as GitHub repo secrets in production.
VERCEL_PROD_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=


# ============================================================================
# ENCRYPTION KEYS & SECRETS
# ============================================================================
# Generate ONCE per environment. Rotating these invalidates every stored
# OAuth token + credential — users must re-authorize all integrations.
#
# INTEGRATION_ENCRYPTION_KEY (AES-128-CBC via Fernet, for OAuth tokens at rest)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
INTEGRATION_ENCRYPTION_KEY=

# INTEGRATION_OAUTH_STATE_SECRET (signs OAuth state JWTs for CSRF protection)
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
INTEGRATION_OAUTH_STATE_SECRET=

# CREDENTIALS_AES_KEY (AES-256-GCM, 32 raw bytes, base64 — Artist Credentials Vault)
#   python -c "import secrets, base64; print(base64.b64encode(secrets.token_bytes(32)).decode())"
CREDENTIALS_AES_KEY=


# ============================================================================
# GOOGLE DRIVE AUTH MSANII BACKEND
# ============================================================================
# console.cloud.google.com/apis/credentials → OAuth 2.0 Client ID.
# Redirect URI to register: {BACKEND_URL}/integrations/google-drive/callback
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=


# ============================================================================
# SLACK INTEGRATION
# ============================================================================
# api.slack.com/apps → your app → Basic Information.
# Redirect URI: {BACKEND_URL}/integrations/slack/callback
# Required OAuth scopes: channels:read, chat:write, commands, incoming-webhook
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=


# ============================================================================
# NOTION INTEGRATION
# ============================================================================
# notion.so/profile/integrations → New integration (public, OAuth).
# Redirect URI: {BACKEND_URL}/integrations/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=


# ============================================================================
# POSTHOG
# ============================================================================
# Master toggle. Set to "true" only in production + staging so dev/test
# environments don't pollute the project. Tests force off via fixture.
POSTHOG_ENABLED=false

# Project API key (the public "Project key", NOT the personal/private key).
# Format: phc_XXXXXXXXXXXXXX. Safe to ship to the browser.
# Get from PostHog Dashboard → Project settings → Project API Key.
VITE_POSTHOG_PROJECT_TOKEN=
POSTHOG_PROJECT_TOKEN=

# API host. US cloud (default), EU cloud, or self-hosted URL.
VITE_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# Dashboard URL — used by the "View Analytics" link in /admin/users.
VITE_POSTHOG_DASHBOARD_URL=https://us.posthog.com

# Tag PostHog events with the deployment environment. Mirrors backend APP_ENV.
# Vercel sets this per env (prod / dev). Leave unset locally — defaults to
# "local" and dashboards filter it out.
# VITE_APP_ENV=

# Personal API Key (read access for admin summary endpoint + setup script).
# DIFFERENT from POSTHOG_PROJECT_TOKEN. Create at PostHog → Personal API Keys.
# Required scopes: query:read, insight:read/write, dashboard:read/write,
# cohort:read/write.
POSTHOG_PERSONAL_API_KEY=

# Numeric project ID (from your PostHog project URL).
POSTHOG_PROJECT_ID=


# ============================================================================
# STRIPE INTEGRATION
# ============================================================================
# See docs/stripe-integration.md for the full local-test runbook (Stripe CLI).
#
# API secret key. Test mode: sk_test_...; live mode: sk_live_...
# dashboard.stripe.com/apikeys (toggle test/live in the UI)
STRIPE_SECRET_KEY=

# Webhook signing secret for /billing/webhook signature verification.
# Local:  output of `stripe listen --forward-to http://localhost:8000/billing/webhook`
# Prod:   Dashboard → Developers → Webhooks → your endpoint → Reveal signing secret
# Different per environment (test vs live).
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs (format: price_XXXXXXXXXXXXXX).
# Create in Dashboard → Products. Test and live prices are separate IDs.
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_ANNUAL=


# ============================================================================
# RESEND SMTP
# ============================================================================
# resend.com → API Keys.
# RESEND_FROM_EMAIL is REQUIRED (no fallback). Address must be on a Resend-
# verified domain — see resend.com/domains.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Msanii <noreply@msanii-beta.com>


# ============================================================================
# LOCAL TESTING VARS & LOCAL ADMIN RIGHTS
# ============================================================================
# Bootstrap admin allowlist (comma-separated, case-insensitive). Users in this
# list always count as admins. Additional admins managed via the /admin/users
# UI (sets profiles.is_admin=true in DB). Env is the recovery path: works even
# if the DB is unreachable; env admins can't be demoted via the UI (must
# remove from env). For prod, store in GSM. See docs/admin-roles.md.
# Example: ADMIN_EMAILS=tech@greenboxanalytics.ca,founder@greenboxanalytics.ca
ADMIN_EMAILS=

# Where Pro-access requests submitted via /pro-requests are emailed.
OPS_NOTIFICATION_EMAIL=tech@greenboxanalytics.ca

# Beta access code gate (optional). When set, gates the entire app behind
# this shared code via src/components/AccessGate.tsx. Leave unset to disable.
VITE_ACCESS_CODE=

# Master paywall override. When "true", ALL users receive Pro-shaped
# entitlements (caps = -1, all features true) regardless of subscription.
# Default: "false" — paywalls fire normally. Set "true" only to demo the
# full-Pro UX locally; never in prod. Admins always get Pro entitlements at
# /me/entitlements regardless of this flag.
BYPASS_PAYWALLS=false

# URLs — defaults are localhost for dev.
VITE_BACKEND_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8080
VITE_FRONTEND_URL=http://localhost:8080
ALLOWED_ORIGINS=http://localhost:8080

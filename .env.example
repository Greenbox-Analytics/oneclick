# Supabase Configuration
VITE_SUPABASE_URL=your-project-url-here
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_SECRET_KEY=your-secret-key-here
DATABASE_PW=your-database-password-here

# Backend API Configuration
# Local:      http://localhost:8000
# Dev:        https://msanii-backend-dev-xxx-nn.a.run.app (deployed on push to main)
# Production: https://msanii-backend-xxx-nn.a.run.app (deployed on tag release v*)
VITE_BACKEND_API_URL=http://localhost:8000

# CORS Configuration (for backend deployment)
# Comma-separated list of allowed origins
# Dev:        Set via DEV_ALLOWED_ORIGINS GitHub secret (dev Vercel URL)
# Production: Set in deploy-backend.yml (prod Vercel URL)
ALLOWED_ORIGINS=http://localhost:8080

# OpenAI Configuration (for backend)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_LLM_MODEL=
OPENAI_LLM_MODEL_LARGE=

# Claude Configuration
CLAUDE_API_KEY=
CLAUDE_MODEL=
CLAUDE_BASE_URL=https://api.anthropic.com/v1

# Vercel Deployment
VERCEL_PROD_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
